{
  "private": true,
  "name": "parent",
  "version": "0.1.0",
  "engines": {
    "node": ">=16.15.1"
  },
  "scripts": {
    "prepare": "npm run icons",
    "ci": "npm install && npm run icons && npm run type && npm run lint:ci && npm run test:ci && npm run standalone build:production",
    "clean": "lerna run clean",
    "build": "lerna run --ignore=@axonivy/inscription-standalone build",
    "build:clean": "lerna run build:clean",
    "type": "lerna run type",
    "lint": "lerna run lint --",
    "lint:ci": "npm run lint -o eslint.xml -f checkstyle",
    "lint:fix": "lerna run lint:fix --",
    "icons": "npm run --prefix packages/icons build",
    "dev": "npm run --prefix integrations/standalone start:mock",
    "start": "npm run --prefix integrations/standalone start",
    "test": "npm run --prefix packages/editor test",
    "test:ci": "lerna run test:ci"
  },
  "devDependencies": {
    "@types/node": "^16.7.13",
    "copyfiles": "2.4.1",
    "eslint": "^8.32.0",
    "eslint-config-react-app": "^7.0.1",
    "lerna": "^6.1.0",
    "rimraf": "^4.1.1",
    "typescript": "~4.9.4"
  },
  "workspaces": [
    "packages/*",
    "integrations/*"
  ]
}
